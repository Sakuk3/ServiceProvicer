{
  "extends": "./tsconfig.json",
  "include": ["src/**/*.ts", "test/**/*.ts", "vitest.config.mts"],
  "exclude": ["node_modules"],
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "types": ["node", "vitest/globals"]
  }
}
