{
  "name": "service-provider-registry",
  "version": "1.0.0",
  "description": "Typed service registry for dependency-aware service composition and lifecycle orchestration.",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./registry": {
      "types": "./dist/registry/index.d.ts",
      "default": "./dist/registry/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "typescript",
    "service-registry",
    "dependency-injection",
    "lifecycle"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/serviceProvider.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/serviceProvider/issues"
  },
  "homepage": "https://github.com/your-org/serviceProvider#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "tsx ./examples/demo.ts",
    "start:watch": "tsx watch ./examples/demo.ts",
    "build": "npm run clean && tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:typecheck": "tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint --fix {src,test,examples}/**/*.{js,ts,jsx,tsx} --no-error-on-unmatched-pattern",
    "format": "prettier --write {src,test,examples}/**/* ./*.{json,*.json} !package-lock.json -u --no-error-on-unmatched-pattern",
    "verify": "npm run lint && npm run format && npm run test && npm run test:typecheck && npm run build",
    "pack:check": "npm pack --dry-run",
    "clean": "rm -rf dist build package",
    "prepare": "husky",
    "prepublishOnly": "npm run verify"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-tsdoc": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.1.7",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "{src,test,examples}/**/*.{js,ts,jsx,tsx}": [
      "eslint --fix",
      "prettier --write -u"
    ],
    "!**/*.{js,ts,jsx,tsx}": "prettier --write -u"
  }
}
